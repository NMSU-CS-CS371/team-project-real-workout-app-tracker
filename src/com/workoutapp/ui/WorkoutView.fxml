<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.workoutapp.ui.WorkoutController"
      spacing="20" alignment="TOP_CENTER">

    <padding>
        <Insets top="20" left="20" right="20" bottom="20"/>
    </padding>

    <!-- HEADER -->
    <Label text="Workout In Progress" fx:id="topHeaderLabel"
           style="-fx-font-size: 22; -fx-font-weight: bold;"/>

    <HBox spacing="20" alignment="CENTER" prefWidth="300">
        <Label fx:id="statusLabel" style="-fx-font-size: 16;"/>
        <Label fx:id="durationLabel" style="-fx-font-size: 16;"/>
        <Label fx:id="volumeLabel" style="-fx-font-size: 16;"/>
    </HBox>

    <ProgressBar fx:id="progressBar" minHeight="15" prefWidth="300"/>

    <!-- EXERCISE LIST -->
    <ListView fx:id="exerciseList"
        prefHeight="144"  minHeight="72" prefWidth="300"/>

    <Button fx:id="addExerciseButton" 
        text="Add Exercise" prefWidth="200"/>

    <!-- CURRENT EXERCISE DETAILS -->
    <Label fx:id="currentExerciseLabel"
           style="-fx-font-size: 18; -fx-font-weight: bold;"/>

    <HBox spacing="15" alignment="CENTER">
        <VBox spacing="5" alignment="CENTER">
            <Label text="Sets"/>
            <Spinner fx:id="setsSpinner" prefWidth="80"/>
        </VBox>

        <VBox spacing="5" alignment="CENTER">
            <Label text="Reps"/>
            <Spinner fx:id="repsSpinner" prefWidth="80"/>
        </VBox>

        <VBox spacing="5" alignment="CENTER">
            <Label text="Weight (lbs)"/>
            <Spinner fx:id="weightSpinner" prefWidth="80"/>
        </VBox>

        <VBox spacing="5" alignment="CENTER">
            <Label text="Duration (min)"/>
            <Spinner fx:id="durationSpinner" prefWidth="80" visible="false"/>
        </VBox>
    </HBox>

    <!-- NAVIGATION -->
    <HBox spacing="20" alignment="CENTER">
        <Button fx:id="prevButton" text="Previous Exercise" prefWidth="150"/>

        <Button fx:id="nextButton" text="Next Exercise" prefWidth="150"/>
    </HBox>

    <!-- FINISH + CANCEL -->
    <HBox spacing="20" alignment="CENTER">
        <Button fx:id="cancelButton"
            text="Cancel Workout" prefWidth="150"
            style="-fx-background-color: #FF4040; -fx-text-fill: white;"/>
        <Button fx:id="finishButton"
            text="Finish Workout" style="-fx-background-color: #4CAF50; 
            -fx-text-fill: white;" prefWidth="150"/>
    </HBox>

</VBox>
