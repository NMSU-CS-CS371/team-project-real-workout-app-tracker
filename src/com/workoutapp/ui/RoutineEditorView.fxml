<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml" minWidth="700" minHeight="400"
            fx:controller="com.workoutapp.ui.RoutineEditorController">

    <!-- LEFT: Routines -->
    <left>
        <VBox spacing="10" prefWidth="250">
            <padding>
                <Insets top="10" left="10" bottom="10" right="5"/>
            </padding>

            <Label text="Routines" style="-fx-font-size: 16;"/>

            <!-- List of routines (name + #exercises) -->
            <ListView fx:id="routineListView" prefHeight="300" editable="true"/>

            <!-- Rename field (no popup) -->
            <HBox spacing="5">
                <Label text="Name:"/>
                <TextField fx:id="routineNameField" HBox.hgrow="ALWAYS"/>
            </HBox>

            <!-- Bottom-left buttons -->
            <HBox spacing="10">
                <Button fx:id="createRoutineButton" text="Create"/>
                <Button fx:id="deleteRoutineButton" text="Delete"/>
                <Button fx:id="renameRoutineButton" text="Rename"/>
            </HBox>

            <Button fx:id="exitButton" text="Exit to Home" maxWidth="Infinity"/>
        </VBox>
    </left>

    <!-- RIGHT: Exercises in selected routine -->
    <center>
        <VBox spacing="10">
            <padding>
                <Insets top="10" left="5" bottom="10" right="10"/>
            </padding>

            <Label fx:id="routineTitleLabel" text="Select a routine..." style="-fx-font-size: 16;"/>

            <!-- Exercises list -->
            <ListView fx:id="exerciseListView" prefHeight="300"/>

            <!-- Bottom-right buttons -->
            <HBox spacing="10">
                <Button fx:id="addExerciseButton" text="Add Exercise"/>
                <Button fx:id="deleteExerciseButton" text="Delete"/>
                <Button fx:id="moveUpButton" text="Move Up"/>
                <Button fx:id="moveDownButton" text="Move Down"/>
                <Button fx:id="clearExercisesButton" text="Clear"/>
                <Button fx:id="saveRoutineButton" text="Save" style="-fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </center>

</BorderPane>
